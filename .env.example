# Copy to .env and fill in real values — never commit .env
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fyp_tracker
DB_USER=fyp_user
DB_PASS=fyp_pass

REDIS_HOST=localhost
REDIS_PORT=6379
# Railway Redis requires a password — leave blank for local dev
REDIS_PASSWORD=

JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@aauca.ac.rw
MAIL_PASS=your-app-password

FRONTEND_URL=http://localhost:5173
# On Railway, set this to your Vercel URL e.g. https://fyp-tracker.vercel.app
